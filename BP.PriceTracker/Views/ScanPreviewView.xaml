<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BP.PriceTracker.Views.ScanPreviewView"
             Title="ScanPreviewView">
    <VerticalStackLayout>
        <Image x:Name="PreviewImage"
           Aspect="AspectFit"
           HeightRequest="400" />

        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">

            <Button Text="Retake" Command="{Binding RetakeCommand}"/>

            <Button Text="Search" Command="{Binding ConfirmCommand}"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>