<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BP.PriceTracker.Views.ScanPreviewView"
             Title="ScanPreviewView">
    <VerticalStackLayout VerticalOptions="CenterAndExpand">
        <Image x:Name="PreviewImage" Aspect="AspectFit" HeightRequest="400" Source="{Binding PreviewImage}"/>
        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
            <Button Text="Retake" Command="{Binding RetakeCommand}" Style="{StaticResource CancelRoundedButtonStyle}"/>
            <Button Text="Search" Command="{Binding ConfirmCommand}" Style="{StaticResource RoundedButtonStyle}"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>