<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BP.PriceTracker.Views.HomeView"
             Title="Categories"
             xmlns:viewModels="clr-namespace:BP.PriceTracker.ViewModels"
             xmlns:controls="clr-namespace:BP.PriceTracker.Controls.Controls;assembly=BP.PriceTracker.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewModels:HomeViewModel">
    <VerticalStackLayout>
        <Button Grid.Column="0" Text="Filter" Style="{StaticResource SecondaryRoundedButtonStyle}" Command="{Binding GoToFilterCommand}"/>
        <Button Grid.Column="1" Text="Scan" Style="{StaticResource RoundedButtonStyle}" Command="{Binding ScanCommand}"/>
    </VerticalStackLayout>
</ContentPage>